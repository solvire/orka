###############################################################################
# Orka Tools — example environment file
#
# Copy this file to .env in your project root and fill in the values you need.
# Orka loads .env from the current working directory automatically.
#
# You can also set ORKA_ENV_FILE to point to a shared env file:
#
#     export ORKA_ENV_FILE=~/.config/orka/env
#
# All settings are optional — Orka works out of the box with just an API key
# for your chosen provider.
###############################################################################

# ============================================================================
# Provider selection
# ============================================================================

# Which LLM provider to use by default.
# Supported values: openai, deepseek, together_ai, gemini, anthropic, openai_compat
# ORKA_DEFAULT_PROVIDER=together_ai


# ============================================================================
# API keys
#
# Standard environment variable names so a single .env works across tools.
# ============================================================================

OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
TOGETHER_API_KEY=...
GEMINI_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...
ZAI_API_KEY=...                        # Zhipu AI / BigModel (GLM-5.2) — open.bigmodel.cn

# Generic fallback for any OpenAI-compatible provider not listed above.
# API_KEY=


# ============================================================================
# Model tiers
#
# Orka uses three model tiers, inspired by Aider's model system:
#
#   smart  — high-quality model for architecture, planning, complex reasoning
#   fast   — cheap/fast model for summarisation, simple edits
#   edit   — model used for surgical code transformations (defaults to smart)
#
# Each tier falls back in this order:
#   1. Explicit ORKA_*_MODEL variable
#   2. Provider-specific variable (e.g. TOGETHER_MODEL for together_ai)
#   3. Built-in default for the provider
# ============================================================================

# ORKA_SMART_MODEL=
# ORKA_FAST_MODEL=
# ORKA_EDIT_MODEL=

# Provider-specific model overrides (tier 2 fallback for the matching provider).
# These are ignored unless ORKA_DEFAULT_PROVIDER matches the prefix.
# OPENAI_MODEL=
# DEEPSEEK_MODEL=
# TOGETHER_MODEL=
# GEMINI_MODEL=
# ANTHROPIC_MODEL=


# ============================================================================
# API connectivity
# ============================================================================

# Generic base URL for OpenAI-compatible providers (OpenRouter, Groq, etc.)
# API_BASE=

# Per-provider API base URLs (defaults shown for reference)
# OPENAI_API_BASE=https://api.openai.com/v1
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1


# ============================================================================
# Client behaviour
# ============================================================================

# ORKA_TEMPERATURE=0.1
# ORKA_TIMEOUT=120          # seconds
# ORKA_MAX_RETRIES=3
# ORKA_VERIFY_SSL=true


# ============================================================================
# Behavioural flags
# ============================================================================

# Automatically re-scan the codebase after mutations (extract/refactor).
# ORKA_AUTO_SCAN=true

# Dry-run mode — print what would change without modifying files.
# ORKA_DRY_RUN=false

# Enable verbose logging.
# ORKA_VERBOSE=false

# Log training data (prompt->completion pairs) from surgery runs for fine-tuning.
# Data is stored locally in .orka/training/ (never transmitted).
# View with: orka training
# Export with: orka training --export dataset.jsonl
# ORKA_LOG_TRAINING=false

# Custom training data directory (default: .orka/training/).
# ORKA_TRAINING_DIR=.orka/training


# ============================================================================
# Alternative env file (bypasses CWD-based .env auto-detection)
# ============================================================================

# ORKA_ENV_FILE=/absolute/path/to/.env
